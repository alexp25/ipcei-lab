{
  "version": 7,
  "cmakeMinimumRequired": {
    "major": 3
  },
  "configurePresets": [
    {
      "name": "debug-env",
      "displayName": "debug-env",
      "hidden": true,
      "environment": {
        "ARMGCC_DIR": "$penv{USERPROFILE}/.mcuxpressotools/arm-gnu-toolchain-14.2.rel1-mingw-w64-x86_64-arm-none-eabi",
        "SdkRootDirPath": "${sourceDir}/../../sdks",
        "MCUX_VENV_PATH": "C:/Users/alex predescu/.mcuxpressotools/.mcux-venv-3.12/Scripts",
        "PATH": "$env{MCUX_VENV_PATH}${pathListSep}$penv{PATH}",
        "POSTPROCESS_UTILITY": "$penv{USERPROFILE}/.mcuxpressotools/mcux-fixelf-14.2.2/mcux-fixelf.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "cacheVariables": {}
    },
    {
      "name": "release-env",
      "displayName": "release-env",
      "hidden": true,
      "environment": {
        "ARMGCC_DIR": "$penv{USERPROFILE}/.mcuxpressotools/arm-gnu-toolchain-14.2.rel1-mingw-w64-x86_64-arm-none-eabi",
        "SdkRootDirPath": "${sourceDir}/../../sdks",
        "MCUX_VENV_PATH": "$penv{USERPROFILE}/.mcuxpressotools/.mcux-venv-3.12/Scripts",
        "PATH": "$env{MCUX_VENV_PATH}${pathListSep}$penv{PATH}",
        "POSTPROCESS_UTILITY": "$penv{USERPROFILE}/.mcuxpressotools/mcux-fixelf-14.2.2/mcux-fixelf.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "cacheVariables": {}
    }
  ],
  "buildPresets": []
}